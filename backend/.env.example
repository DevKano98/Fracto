# GEMINI — Two keys, different purposes
GEMINI_KEY_1=                    # OCR + Vision only (gemini_ocr_service.py)
GEMINI_KEY_2=                    # Verification + blog generation only

# GROQ — Free Qwen pre-analyzer (14400 req/day)
GROQ_API_KEY=                    # from console.groq.com, free, no card

# SARVAM — STT + TTS + language detection
SARVAM_API_KEY=                  # from dashboard.sarvam.ai, free credits

# SUPABASE — database + realtime + storage
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=               # anon public key from Settings > API

# CLOUDINARY — blog image CDN
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# REPLICATE — SDXL blog cover image generation
REPLICATE_API_TOKEN=             # from replicate.com, free credits

# UPSTASH REDIS — cache + deduplication + trending
UPSTASH_REDIS_URL=https://your-db.upstash.io
UPSTASH_REDIS_TOKEN=

# NEWSAPI — verified news scraping
NEWS_API_KEY=                    # from newsapi.org, 100/day free

# MEDIASTACK — live news API (scraping / sources)
MEDIASTACK_API_KEY=              # from mediastack.com, free tier available

# GOOGLE CUSTOM SEARCH — targeted web search
GOOGLE_CSE_KEY=                  # Google API key from console.cloud.google.com
GOOGLE_CSE_CX=                   # Custom Search Engine ID from cse.google.com

# REDDIT — India subreddit scraping
REDDIT_CLIENT_ID=                # from reddit.com/prefs/apps
REDDIT_CLIENT_SECRET=

# YOUTUBE — Hindi news channel search
YOUTUBE_API_KEY=                 # YouTube Data API v3, 10000 units/day free

# TELEGRAM — public Indian channels
TELEGRAM_API_ID=                 # from my.telegram.org, integer
TELEGRAM_API_HASH=               # from my.telegram.org

# OPENROUTER — Free fallback for image (Gemma 3 4B) + reasoning (Qwen3 80B) when Gemini fails
OPENROUTER_API_KEY=              # from openrouter.ai, free tier

# APP CONFIG
APP_SECRET_KEY=                  # python -c "import secrets; print(secrets.token_hex(32))"
ENVIRONMENT=development
RISK_BLOG_THRESHOLD=6.0
RISK_ACTION_THRESHOLD=7.0
CONFLICT_THRESHOLD=0.20
